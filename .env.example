# Calcheq — environment variables
# Copy this file to backend/.env for local development.
# In production (Railway), set these directly in the Railway dashboard.

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase: Settings > Database > Connection string > URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL (Supabase: Settings > API > Project URL)
SUPABASE_URL=https://<project-ref>.supabase.co

# Anon / public key (Supabase: Settings > API > Project API keys)
SUPABASE_ANON_KEY=<your-anon-key>

# ── Security ────────────────────────────────────────────────────────────────
# Random secret used to sign JWTs — generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-secret

# ── Platform operator / super-admin ────────────────────────────────────────
# Comma-separated list of emails that are granted platform-wide super-admin
# privileges (list/manage every site, extend trials, impersonate). Gated
# entirely by this env var — super-admin is NOT a DB role. Leave empty to
# disable super-admin features. Matched case-insensitively; whitespace trimmed.
# Example: SUPERADMIN_EMAILS=nfish82@hotmail.com,ops@calcheq.com
SUPERADMIN_EMAILS=

# ── App ─────────────────────────────────────────────────────────────────────
# development | production
ENVIRONMENT=development

# The public URL of your deployed app (Railway: Settings > Domains)
# Used to restrict CORS in production. Only required when ENVIRONMENT=production.
# Example: https://calcheq.com
FRONTEND_URL=https://<your-app>.up.railway.app
