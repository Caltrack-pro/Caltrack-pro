# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT
# ──────────────────────────────────────────────────────────────────────────────
# Get DATABASE_URL from: Supabase → Project Settings → Database → Connection string
# Use the "Transaction pooler" URL (port 6543) — NOT the direct connection.
DATABASE_URL=postgresql://postgres.qdrgjjndwgrmmjvzzdhg:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

ENVIRONMENT=development

# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-secret

# ──────────────────────────────────────────────────────────────────────────────
# RAILWAY PRODUCTION — set these as environment variables in the Railway dashboard
# ──────────────────────────────────────────────────────────────────────────────
# DATABASE_URL   = same Supabase transaction pooler URL as above
# ENVIRONMENT    = production
# SECRET_KEY     = a long random string (run the python command above to generate one)
#
# That's it. FRONTEND_URL is not required — FastAPI serves the React app directly.
