# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT
# ──────────────────────────────────────────────────────────────────────────────
# Get DATABASE_URL from: Supabase → Project Settings → Database → Connection string
# Use the "Transaction pooler" URL (port 6543) — NOT the direct connection.
DATABASE_URL=postgresql://postgres.qdrgjjndwgrmmjvzzdhg:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

ENVIRONMENT=development

# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-secret

# ──────────────────────────────────────────────────────────────────────────────
# SUPABASE AUTH
# ──────────────────────────────────────────────────────────────────────────────
# Your Supabase project URL — used to fetch the public JWKS for JWT verification.
# Supabase now signs tokens with ECC P-256 (ES256 asymmetric keys), so the backend
# fetches public keys from: {SUPABASE_URL}/auth/v1/.well-known/jwks.json
# Get from: Supabase Dashboard → Project Settings (or the API URL shown in Data API)
SUPABASE_URL=https://qdrgjjndwgrmmjvzzdhg.supabase.co

# Legacy HS256 secret — only needed if SUPABASE_URL is not set (local dev fallback).
# If SUPABASE_URL is set, this is ignored.
SUPABASE_JWT_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# EMAIL NOTIFICATIONS (Resend — https://resend.com)
# ──────────────────────────────────────────────────────────────────────────────
# Get your API key from: resend.com → API Keys
# RESEND_FROM_EMAIL must be a verified sender address (or use onboarding@resend.dev for testing)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Calcheq <notifications@calcheq.com>

# Public URL used in email links (no trailing slash)
APP_URL=https://calcheq.com

# ──────────────────────────────────────────────────────────────────────────────
# RAILWAY PRODUCTION — set these as environment variables in the Railway dashboard
# ──────────────────────────────────────────────────────────────────────────────
# DATABASE_URL         = same Supabase transaction pooler URL as above
# ENVIRONMENT          = production
# SECRET_KEY           = a long random string (run the python command above)
# SUPABASE_URL         = https://qdrgjjndwgrmmjvzzdhg.supabase.co  ← ADD THIS
# SUPABASE_JWT_SECRET  = (can be removed — SUPABASE_URL replaces it)
# APP_URL              = https://calcheq.com  (update once custom domain is live)
#
# Frontend env vars (set in Railway OR as VITE_ vars in your build step):
#   VITE_SUPABASE_URL      = https://qdrgjjndwgrmmjvzzdhg.supabase.co
#   VITE_SUPABASE_ANON_KEY = (anon/public key from Supabase → Project Settings → API)
#   VITE_DEMO_EMAIL        = demo@calcheq.com   (optional — for the demo sign-in button)
#   VITE_DEMO_PASSWORD     = (password for the demo account)
