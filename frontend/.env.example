# Copy this file to frontend/.env.local for local development.
# These variables are injected into the React build by Vite.
# In Railway production, set them as environment variables in your service.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional — used by the "Try Demo" button on the sign-in page.
# Create a demo account in Supabase and add it to the Demo site.
VITE_DEMO_EMAIL=demo@your-domain.com
VITE_DEMO_PASSWORD=your-demo-account-password
