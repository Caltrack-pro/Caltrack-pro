# Copy this file to keystore.properties and fill in the real values.
# keystore.properties is gitignored — never commit your real passwords.
#
# storePassword/keyPassword: the two passwords you typed when running
#   keytool -genkey ... (usually the same one)
# keyAlias: the -alias value from that same command (we used "calcheq")
# storeFile: path to the .keystore file, relative to frontend/android/app/

storePassword=YOUR_STORE_PASSWORD_HERE
keyPassword=YOUR_KEY_PASSWORD_HERE
keyAlias=calcheq
storeFile=calcheq-release.keystore
